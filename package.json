{
  "name": "sauce-demo-automacao",
  "version": "1.0.0",
  "description": "Portfólio de automação de testes com atualizações diárias, usando Cypress, Playwright e Postman.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "pw:test": "playwright test",
    "pw:test:ui": "playwright test --ui",
    "pw:report": "playwright show-report",
    "pw:summary": "node scripts/playwright-summary.js",
    "api:test": "newman run postman/collections/day-000-api-warmup.postman_collection.json -e postman/environments/jsonplaceholder.postman_environment.json",
    "typecheck": "tsc --noEmit",
    "test:all": "npm run typecheck && npm run cy:run && npm run pw:test && npm run api:test"
  },
  "keywords": [
    "qa",
    "automation",
    "cypress",
    "playwright",
    "postman",
    "portfolio"
  ],
  "author": "Flavio",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "cypress": "^15.18.0",
    "newman": "^6.2.2",
    "typescript": "^6.0.3"
  }
}
