{
  "info": {
    "name": "Dia 004 - DummyJSON Auth API",
    "description": "Collection para autenticação, usuários e paginação em DummyJSON.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "POST /auth/login - credenciais válidas",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\",\n  \"expiresInMins\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code é 200', () => pm.response.to.have.status(200));",
                  "pm.test('Resposta retorna accessToken e dados do usuário', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json.accessToken).to.be.a('string');",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.username).to.be.a('string');",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login - credenciais inválidas",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"senhaerrada\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code é 400', () => pm.response.to.have.status(400));",
                  "pm.test('Resposta retorna mensagem de erro', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Usuários e Paginação",
      "item": [
        {
          "name": "GET /users?limit=10&skip=10 - validar paginação",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?limit=10&skip=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "skip", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code é 200', () => pm.response.to.have.status(200));",
                  "pm.test('Resposta possui estrutura de paginação', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json.users).to.be.an('array');",
                  "  pm.expect(json.total).to.be.a('number');",
                  "  pm.expect(json.skip).to.be.a('number');",
                  "  pm.expect(json.limit).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /users/1 - buscar usuário específico",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code é 200', () => pm.response.to.have.status(200));",
                  "pm.test('Resposta possui estrutura do usuário', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json.id).to.equal(1);",
                  "  pm.expect(json.username).to.be.a('string');",
                  "  pm.expect(json.email).to.be.a('string');",
                  "  pm.expect(json.address).to.be.an('object');",
                  "  pm.expect(json.company).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /users/9999 - usuário inexistente",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/9999",
              "host": ["{{baseUrl}}"],
              "path": ["users", "9999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code é 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
